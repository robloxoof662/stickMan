{
  "name": "stickman-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc --noEmit && vite build",
    "test": "node --import tsx --test server/**/*.test.ts",
    "start": "NODE_ENV=production tsx server/index.ts"
  },
  "dependencies": {
    "three": "^0.178.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/three": "^0.178.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.6"
  }
}
